# Copy to .env.local — never commit .env.local

# Agent Workbench 运行时根目录（queue / runs / missions / state）
AGENT_WORKBENCH_ROOT=E:\AgentWorkbench

# 本仓库绝对路径
JUNO_OVERSIGHT_ROOT=C:\Users\kfr34\Desktop\Entrepreneurship\Juno Oversight

# Cursor Composer Live spawn（必需，若跑 book:loop / agi:loop Live slot）
CURSOR_API_KEY=

# 可选：queue item 使用 provider: api_token 时的 OpenAI 兼容 API
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# 可选：强制 Scheduler 启用 loop gate
# JUNO_REQUIRE_LOOP_GATE=1
